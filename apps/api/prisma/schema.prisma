generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, uuid_ossp(map: "uuid-ossp")]
}

enum UserRole {
  creator
  business
  admin
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  trialing
}

enum CampaignStatus {
  draft
  active
  paused
  completed
  canceled
}

enum DealStatus {
  pending
  accepted
  in_progress
  content_submitted
  approved
  completed
  disputed
  canceled
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  refunded
}

enum ContentType {
  instagram_post
  instagram_story
  instagram_reel
  tiktok_video
  youtube_video
  blog_post
  other
}

enum NicheCategory {
  food
  fashion
  beauty
  fitness
  travel
  lifestyle
  tech
  gaming
  parenting
  pets
  home_decor
  automotive
  entertainment
  education
  other
}

model User {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  role            UserRole
  firstName       String?   @map("first_name") @db.VarChar(100)
  lastName        String?   @map("last_name") @db.VarChar(100)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(500)
  phone           String?   @db.VarChar(20)
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  lastLoginAt     DateTime? @map("last_login_at")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  creatorProfile     CreatorProfile?
  businessProfile    BusinessProfile?
  refreshTokens      RefreshToken[]
  sentMessages       Message[]                @relation("SentMessages")
  conversations1     Conversation[]           @relation("Participant1")
  conversations2     Conversation[]           @relation("Participant2")
  reviewsGiven       Review[]                 @relation("ReviewsGiven")
  reviewsReceived    Review[]                 @relation("ReviewsReceived")
  notifications      NotificationPreference?
  paymentsMade       Transaction[]            @relation("Payer")
  paymentsReceived   Transaction[]            @relation("Payee")

  @@map("users")
}

model CreatorProfile {
  id                      String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                  String         @unique @map("user_id") @db.Uuid
  displayName             String         @map("display_name") @db.VarChar(100)
  bio                     String?        @db.Text
  headline                String?        @db.VarChar(255)
  latitude                Float?
  longitude               Float?
  city                    String?        @db.VarChar(100)
  state                   String?        @db.VarChar(100)
  country                 String         @default("USA") @db.VarChar(100)
  zipCode                 String?        @map("zip_code") @db.VarChar(20)
  serviceRadiusMiles      Int            @default(25) @map("service_radius_miles")
  niches                  NicheCategory[]
  websiteUrl              String?        @map("website_url") @db.VarChar(500)
  baseRateCents           Int?           @map("base_rate_cents")
  ratePerPostCents        Int?           @map("rate_per_post_cents")
  ratePerStoryCents       Int?           @map("rate_per_story_cents")
  ratePerReelCents        Int?           @map("rate_per_reel_cents")
  totalFollowers          Int            @default(0) @map("total_followers")
  avgEngagementRate       Float          @default(0) @map("avg_engagement_rate") @db.DoublePrecision
  completedDealsCount     Int            @default(0) @map("completed_deals_count")
  avgRating               Float          @default(0) @map("avg_rating") @db.DoublePrecision
  reviewCount             Int            @default(0) @map("review_count")
  profileCompleteness     Int            @default(0) @map("profile_completeness")
  isVerified              Boolean        @default(false) @map("is_verified")
  verifiedAt              DateTime?      @map("verified_at")
  stripeAccountId         String?        @map("stripe_account_id") @db.VarChar(255)
  stripeAccountStatus     String?        @map("stripe_account_status") @db.VarChar(50)
  stripeOnboardingComplete Boolean       @default(false) @map("stripe_onboarding_complete")
  isAvailable             Boolean        @default(true) @map("is_available")
  autoAcceptDeals         Boolean        @default(false) @map("auto_accept_deals")
  minDealValueCents       Int?           @map("min_deal_value_cents")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccounts SocialAccount[]
  portfolioItems PortfolioItem[]
  matchScores    MatchScore[]
  deals          Deal[]

  // PostGIS geometry column kept in sync with latitude/longitude via DB trigger
  // (see prisma/migrations/manual/postgis.sql). GIST index lives there too.
  location Unsupported("geometry(Point, 4326)")?

  @@index([totalFollowers])
  @@index([avgEngagementRate])
  @@index([isAvailable])
  @@map("creator_profiles")
}

model SocialAccount {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  creatorId            String    @map("creator_id") @db.Uuid
  platform             String    @db.VarChar(50)
  platformUserId       String?   @map("platform_user_id") @db.VarChar(255)
  username             String?   @db.VarChar(255)
  profileUrl           String?   @map("profile_url") @db.VarChar(500)
  accessTokenEncrypted String?   @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?  @map("refresh_token_encrypted") @db.Text
  tokenExpiresAt       DateTime? @map("token_expires_at")
  followersCount       Int       @default(0) @map("followers_count")
  followingCount       Int       @default(0) @map("following_count")
  postsCount           Int       @default(0) @map("posts_count")
  avgLikes             Int       @default(0) @map("avg_likes")
  avgComments          Int       @default(0) @map("avg_comments")
  engagementRate       Float     @default(0) @map("engagement_rate") @db.DoublePrecision
  audienceDemographics Json?     @map("audience_demographics")
  topHashtags          Json?     @map("top_hashtags")
  postingFrequency     Float?    @map("posting_frequency") @db.DoublePrecision
  lastSyncedAt         DateTime? @map("last_synced_at")
  isPrimary            Boolean   @default(false) @map("is_primary")
  isConnected          Boolean   @default(true) @map("is_connected")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, platform])
  @@index([platform])
  @@map("social_accounts")
}

model PortfolioItem {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  creatorId     String    @map("creator_id") @db.Uuid
  title         String?   @db.VarChar(255)
  description   String?   @db.Text
  mediaType     String    @map("media_type") @db.VarChar(50)
  mediaUrl      String    @map("media_url") @db.VarChar(500)
  thumbnailUrl  String?   @map("thumbnail_url") @db.VarChar(500)
  externalLink  String?   @map("external_link") @db.VarChar(500)
  platform      String?   @db.VarChar(50)
  likesCount    Int?      @map("likes_count")
  commentsCount Int?      @map("comments_count")
  viewsCount    Int?      @map("views_count")
  campaignId    String?   @map("campaign_id") @db.Uuid
  brandName     String?   @map("brand_name") @db.VarChar(255)
  isFeatured    Boolean   @default(false) @map("is_featured")
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@map("portfolio_items")
}

model BusinessProfile {
  id                     String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                 String              @unique @map("user_id") @db.Uuid
  businessName           String              @map("business_name") @db.VarChar(255)
  businessType           String?             @map("business_type") @db.VarChar(100)
  description            String?             @db.Text
  logoUrl                String?             @map("logo_url") @db.VarChar(500)
  coverImageUrl          String?             @map("cover_image_url") @db.VarChar(500)
  latitude               Float?
  longitude              Float?
  addressLine1           String?             @map("address_line1") @db.VarChar(255)
  addressLine2           String?             @map("address_line2") @db.VarChar(255)
  city                   String?             @db.VarChar(100)
  state                  String?             @db.VarChar(100)
  country                String              @default("USA") @db.VarChar(100)
  zipCode                String?             @map("zip_code") @db.VarChar(20)
  targetNiches           NicheCategory[]     @map("target_niches")
  preferredFollowerMin   Int?                @map("preferred_follower_min")
  preferredFollowerMax   Int?                @map("preferred_follower_max")
  preferredEngagementMin Float?              @map("preferred_engagement_min") @db.DoublePrecision
  websiteUrl             String?             @map("website_url") @db.VarChar(500)
  instagramUrl           String?             @map("instagram_url") @db.VarChar(500)
  contactEmail           String?             @map("contact_email") @db.VarChar(255)
  contactPhone           String?             @map("contact_phone") @db.VarChar(20)
  stripeCustomerId       String?             @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId   String?             @map("stripe_subscription_id") @db.VarChar(255)
  subscriptionStatus     SubscriptionStatus? @map("subscription_status")
  subscriptionPlan       String?             @map("subscription_plan") @db.VarChar(50)
  subscriptionStartedAt  DateTime?           @map("subscription_started_at")
  subscriptionEndsAt     DateTime?           @map("subscription_ends_at")
  trialEndsAt            DateTime?           @map("trial_ends_at")
  activeCampaignsCount   Int                 @default(0) @map("active_campaigns_count")
  completedDealsCount    Int                 @default(0) @map("completed_deals_count")
  totalSpentCents        BigInt              @default(0) @map("total_spent_cents")
  isVerified             Boolean             @default(false) @map("is_verified")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns            Campaign[]
  deals                Deal[]
  subscriptionPayments SubscriptionPayment[]

  // PostGIS geometry column kept in sync with latitude/longitude via DB trigger.
  location Unsupported("geometry(Point, 4326)")?

  @@index([subscriptionStatus])
  @@map("business_profiles")
}

model Campaign {
  id                   String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  businessId           String         @map("business_id") @db.Uuid
  title                String         @db.VarChar(255)
  description          String?        @db.Text
  objective            String?        @db.Text
  requiredContentTypes ContentType[]  @map("required_content_types")
  requiredDeliverables Json           @map("required_deliverables")
  brandGuidelines      String?        @map("brand_guidelines") @db.Text
  hashtags             String[]
  mentions             String[]
  targetNiches         NicheCategory[] @map("target_niches")
  minFollowers         Int?           @map("min_followers")
  maxFollowers         Int?           @map("max_followers")
  minEngagementRate    Float?         @map("min_engagement_rate") @db.DoublePrecision
  targetLatitude       Float?         @map("target_latitude")
  targetLongitude      Float?         @map("target_longitude")
  targetRadiusMiles    Int            @default(25) @map("target_radius_miles")
  budgetCents          Int            @map("budget_cents")
  paymentPerCreatorCents Int?         @map("payment_per_creator_cents")
  maxCreators          Int            @default(1) @map("max_creators")
  startDate            DateTime?      @map("start_date") @db.Date
  endDate              DateTime?      @map("end_date") @db.Date
  contentDeadline      DateTime?      @map("content_deadline") @db.Date
  status               CampaignStatus @default(draft)
  invitedCount         Int            @default(0) @map("invited_count")
  appliedCount         Int            @default(0) @map("applied_count")
  acceptedCount        Int            @default(0) @map("accepted_count")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  business    BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)
  matchScores MatchScore[]
  deals       Deal[]

  @@index([businessId])
  @@index([status])
  @@map("campaigns")
}

model MatchScore {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  campaignId        String   @map("campaign_id") @db.Uuid
  creatorId         String   @map("creator_id") @db.Uuid
  overallScore      Int      @map("overall_score")
  nicheScore        Int?     @map("niche_score")
  locationScore     Int?     @map("location_score")
  engagementScore   Int?     @map("engagement_score")
  followerScore     Int?     @map("follower_score")
  priceScore        Int?     @map("price_score")
  availabilityScore Int?     @map("availability_score")
  historyScore      Int?     @map("history_score")
  matchReasoning    Json?    @map("match_reasoning")
  isRecommended     Boolean  @default(false) @map("is_recommended")
  wasInvited        Boolean  @default(false) @map("was_invited")
  wasViewed         Boolean  @default(false) @map("was_viewed")
  calculatedAt      DateTime @default(now()) @map("calculated_at")

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator  CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([campaignId, creatorId])
  @@index([campaignId, overallScore(sort: Desc)])
  @@index([creatorId])
  @@map("match_scores")
}

model Deal {
  id                  String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  campaignId          String        @map("campaign_id") @db.Uuid
  businessId          String        @map("business_id") @db.Uuid
  creatorId           String        @map("creator_id") @db.Uuid
  agreedAmountCents   Int           @map("agreed_amount_cents")
  platformFeeCents    Int?          @map("platform_fee_cents")
  creatorPayoutCents  Int?          @map("creator_payout_cents")
  deliverables        Json
  specialRequirements String?       @map("special_requirements") @db.Text
  status              DealStatus    @default(pending)
  proposedAt          DateTime      @default(now()) @map("proposed_at")
  acceptedAt          DateTime?     @map("accepted_at")
  startedAt           DateTime?     @map("started_at")
  contentSubmittedAt  DateTime?     @map("content_submitted_at")
  approvedAt          DateTime?     @map("approved_at")
  completedAt         DateTime?     @map("completed_at")
  canceledAt          DateTime?     @map("canceled_at")
  canceledBy          String?       @map("canceled_by") @db.Uuid
  cancellationReason  String?       @map("cancellation_reason") @db.Text
  paymentStatus       PaymentStatus @default(pending) @map("payment_status")
  paymentIntentId     String?       @map("payment_intent_id") @db.VarChar(255)
  paidAt              DateTime?     @map("paid_at")
  businessNotes       String?       @map("business_notes") @db.Text
  creatorNotes        String?       @map("creator_notes") @db.Text
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  business      BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Restrict)
  creator       CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Restrict)
  submissions   DealSubmission[]
  reviews       Review[]
  conversations Conversation[]
  transactions  Transaction[]

  @@index([campaignId])
  @@index([businessId, status, createdAt(sort: Desc)])
  @@index([creatorId, status, createdAt(sort: Desc)])
  @@index([status])
  @@map("deals")
}

model DealSubmission {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealId          String      @map("deal_id") @db.Uuid
  contentType     ContentType @map("content_type")
  contentUrl      String?     @map("content_url") @db.VarChar(500)
  thumbnailUrl    String?     @map("thumbnail_url") @db.VarChar(500)
  caption         String?     @db.Text
  platformPostId  String?     @map("platform_post_id") @db.VarChar(255)
  platformPostUrl String?     @map("platform_post_url") @db.VarChar(500)
  likesCount      Int?        @map("likes_count")
  commentsCount   Int?        @map("comments_count")
  viewsCount      Int?        @map("views_count")
  reach           Int?
  impressions     Int?
  status          String      @default("submitted") @db.VarChar(50)
  revisionNotes   String?     @map("revision_notes") @db.Text
  submittedAt     DateTime    @default(now()) @map("submitted_at")
  approvedAt      DateTime?   @map("approved_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("deal_submissions")
}

model Review {
  id                    String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealId                String   @map("deal_id") @db.Uuid
  reviewerId            String   @map("reviewer_id") @db.Uuid
  revieweeId            String   @map("reviewee_id") @db.Uuid
  rating                Int
  title                 String?  @db.VarChar(255)
  content               String?  @db.Text
  communicationRating   Int?     @map("communication_rating")
  qualityRating         Int?     @map("quality_rating")
  timelinessRating      Int?     @map("timeliness_rating")
  professionalismRating Int?     @map("professionalism_rating")
  isPublic              Boolean  @default(true) @map("is_public")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  deal     Deal @relation(fields: [dealId], references: [id])
  reviewer User @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@unique([dealId, reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

model Conversation {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealId              String?   @map("deal_id") @db.Uuid
  participant1Id      String    @map("participant_1_id") @db.Uuid
  participant2Id      String    @map("participant_2_id") @db.Uuid
  lastMessageAt       DateTime? @map("last_message_at")
  lastMessagePreview  String?   @map("last_message_preview") @db.VarChar(255)
  participant1Unread  Int       @default(0) @map("participant_1_unread")
  participant2Unread  Int       @default(0) @map("participant_2_unread")
  isArchived          Boolean   @default(false) @map("is_archived")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  deal         Deal?     @relation(fields: [dealId], references: [id])
  participant1 User      @relation("Participant1", fields: [participant1Id], references: [id])
  participant2 User      @relation("Participant2", fields: [participant2Id], references: [id])
  messages     Message[]

  // Application sorts participant IDs lexicographically before insert so this
  // unique constraint catches duplicate conversations between the same pair.
  @@unique([participant1Id, participant2Id, dealId])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([dealId])
  @@map("conversations")
}

model Message {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  conversationId    String   @map("conversation_id") @db.Uuid
  senderId          String   @map("sender_id") @db.Uuid
  content           String   @db.Text
  attachmentUrl     String?  @map("attachment_url") @db.VarChar(500)
  attachmentType    String?  @map("attachment_type") @db.VarChar(50)
  isRead            Boolean  @default(false) @map("is_read")
  readAt            DateTime? @map("read_at")
  isSystemMessage   Boolean  @default(false) @map("is_system_message")
  systemMessageType String?  @map("system_message_type") @db.VarChar(50)
  createdAt         DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

model Transaction {
  id                    String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealId                String?       @map("deal_id") @db.Uuid
  payerId               String        @map("payer_id") @db.Uuid
  payeeId               String        @map("payee_id") @db.Uuid
  amountCents           Int           @map("amount_cents")
  platformFeeCents      Int           @map("platform_fee_cents")
  creatorPayoutCents    Int           @map("creator_payout_cents")
  stripePaymentIntentId String?       @map("stripe_payment_intent_id") @db.VarChar(255)
  stripeChargeId        String?       @map("stripe_charge_id") @db.VarChar(255)
  stripeTransferId      String?       @map("stripe_transfer_id") @db.VarChar(255)
  status                PaymentStatus @default(pending)
  errorMessage          String?       @map("error_message") @db.Text
  errorCode             String?       @map("error_code") @db.VarChar(50)
  processedAt           DateTime?     @map("processed_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  deal  Deal? @relation(fields: [dealId], references: [id])
  payer User  @relation("Payer", fields: [payerId], references: [id])
  payee User  @relation("Payee", fields: [payeeId], references: [id])

  @@unique([stripePaymentIntentId])
  @@index([dealId])
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
  @@map("transactions")
}

model SubscriptionPayment {
  id                   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  businessId           String   @map("business_id") @db.Uuid
  stripeInvoiceId      String?  @map("stripe_invoice_id") @db.VarChar(255)
  stripeSubscriptionId String?  @map("stripe_subscription_id") @db.VarChar(255)
  amountCents          Int      @map("amount_cents")
  status               String   @db.VarChar(50)
  billingPeriodStart   DateTime? @map("billing_period_start") @db.Date
  billingPeriodEnd     DateTime? @map("billing_period_end") @db.Date
  paidAt               DateTime? @map("paid_at")
  createdAt            DateTime @default(now()) @map("created_at")

  business BusinessProfile @relation(fields: [businessId], references: [id])

  @@unique([stripeInvoiceId])
  @@index([businessId])
  @@map("subscription_payments")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model NotificationPreference {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  emailNewMatch   Boolean  @default(true) @map("email_new_match")
  emailNewMessage Boolean  @default(true) @map("email_new_message")
  emailDealUpdate Boolean  @default(true) @map("email_deal_update")
  emailPayment    Boolean  @default(true) @map("email_payment")
  emailMarketing  Boolean  @default(false) @map("email_marketing")
  pushNewMatch    Boolean  @default(true) @map("push_new_match")
  pushNewMessage  Boolean  @default(true) @map("push_new_message")
  pushDealUpdate  Boolean  @default(true) @map("push_deal_update")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
